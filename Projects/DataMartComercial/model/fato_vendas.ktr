  <step>
    <name>Table input</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Origem</connection>
    <sql>SELECT 
    p."NumeroDoPedido" AS numero_pedido,
    dp."CodigoDoProduto" AS id_produto_origem,
    p."CodigoDoCliente" AS id_cliente_origem,
    p."CodigoDoFuncionario" AS id_vendedor_origem,
    p."Via" AS id_transportadora_origem,
    p."DataDoPedido" AS data_pedido,
    p."DataDeEnvio" AS data_envio,
    p."DataDeEntrega" AS data_entrega_real,
    dp."PrecoUnitario" AS preco_unitario,
    dp."Quantidade" AS quantidade,
    CAST(dp."Desconto" AS NUMERIC) AS desconto_perc 
FROM public."Pedidos" p
JOIN public."Detalhes do Pedido" dp 
  ON p."NumeroDoPedido" = dp."NumeroDoPedido"</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
