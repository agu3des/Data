    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>//Script here

// 1. Criar SK (Inteiro YYYYMMDD)
// Formata a data para string e remove hifens
var sk_data_str = date2str(data_atual, "yyyyMMdd");
var sk_data = str2num(sk_data_str);

// 2. Criar AnoMes (Inteiro YYYYMM)
var ano_mes_str = date2str(data_atual, "yyyyMM");
var ano_mes = str2num(ano_mes_str);

// 3. Nome do Mês
var nome_mes = "";
if(mes_num == 1) nome_mes = "Janeiro";
else if(mes_num == 2) nome_mes = "Fevereiro";
else if(mes_num == 3) nome_mes = "Março";
else if(mes_num == 4) nome_mes = "Abril";
else if(mes_num == 5) nome_mes = "Maio";
else if(mes_num == 6) nome_mes = "Junho";
else if(mes_num == 7) nome_mes = "Julho";
else if(mes_num == 8) nome_mes = "Agosto";
else if(mes_num == 9) nome_mes = "Setembro";
else if(mes_num == 10) nome_mes = "Outubro";
else if(mes_num == 11) nome_mes = "Novembro";
else if(mes_num == 12) nome_mes = "Dezembro";

// 4. Nome do Dia da Semana e Flag Fim de Semana
// O Calculator retorna 1=Domingo, 2=Segunda... 7=Sábado (Padrão Java/Pentaho)
var nome_dia_semana = "";
var fim_semana = false;
var dia_semana_calc = dia_semana_num; // Recupera do step anterior

if(dia_semana_calc == 1) { 
    nome_dia_semana = "Domingo"; 
    fim_semana = true; 
}
else if(dia_semana_calc == 2) nome_dia_semana = "Segunda-feira";
else if(dia_semana_calc == 3) nome_dia_semana = "Terça-feira";
else if(dia_semana_calc == 4) nome_dia_semana = "Quarta-feira";
else if(dia_semana_calc == 5) nome_dia_semana = "Quinta-feira";
else if(dia_semana_calc == 6) nome_dia_semana = "Sexta-feira";
else if(dia_semana_calc == 7) { 
    nome_dia_semana = "Sábado"; 
    fim_semana = true; 
}

// 5. Nome Trimestre
var nome_trimestre = "Q" + trimestre_num;

// 6. Campos Padrão
var feriado = false;
var nome_feriado = null;</jsScript_script>
      </jsScript>
